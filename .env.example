DEBUG=False

SERVICE_ACCOUNT_SUB=replace-with-service-account-sub

TIP_RESTAURANT_ID=1
E_RESTAURANT_ID=2

# 각종 설정(Debug 변경시 변경 필요)
MEAL_TYPES_FILE_NAME=meal_types.json
USER_SERVICE_URL=http://user-service:8000/
TIMEZONE=Asia/Seoul

# DATABASE_URL 우선 사용 (명시된 경우 POSTGRES_* 무시)
DATABASE_URL=postgresql+asyncpg://postgres:change-this-db-password@meal-service-db:5432/meal_service

KC_SERVER_URL=https://sandol.sio2.kr/auth/
KC_LOCAL_URL=http://keycloak:8080/auth/
KC_CLIENT_ID=sandol-meal-service
KC_CLIENT_SECRET=replace-with-keycloak-client-secret
KC_REALM=Sandori

# docker-compose의 healthcheck는
# 하드코딩 되어 있으므로 꼭 함께 수정
POSTGRES_DB=meal_service
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-db-password
POSTGRES_HOST=meal-service-db
POSTGRES_PORT=5432
